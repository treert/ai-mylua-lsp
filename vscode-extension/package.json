{
  "name": "mylua",
  "displayName": "MyLua",
  "description": "Lua 5.3+ language support with EmmyLua annotations",
  "version": "0.1.0",
  "publisher": "mylua",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:lua"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lua",
        "aliases": ["Lua", "lua"],
        "extensions": [".lua"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lua",
        "scopeName": "source.lua",
        "path": "./syntaxes/lua.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "MyLua",
      "properties": {
        "mylua.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to mylua-lsp executable. If empty, uses bundled or PATH."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
