{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lua",
  "scopeName": "source.lua",
  "patterns": [
    { "include": "#shebang" },
    { "include": "#emmy-comment" },
    { "include": "#block-comment" },
    { "include": "#line-comment" },
    { "include": "#string-double" },
    { "include": "#string-single" },
    { "include": "#string-long" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#constant" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#method-call" },
    { "include": "#label" },
    { "include": "#local-function" },
    { "include": "#operator" },
    { "include": "#variable" }
  ],
  "repository": {
    "shebang": {
      "match": "\\A#!.*$",
      "name": "comment.line.shebang.lua"
    },

    "emmy-comment": {
      "patterns": [
        { "include": "#emmy-class" },
        { "include": "#emmy-field" },
        { "include": "#emmy-param" },
        { "include": "#emmy-return" },
        { "include": "#emmy-type-annotation" },
        { "include": "#emmy-alias" },
        { "include": "#emmy-generic" },
        { "include": "#emmy-overload" },
        { "include": "#emmy-cast" },
        { "include": "#emmy-vararg" },
        { "include": "#emmy-enum" },
        { "include": "#emmy-diagnostic" },
        { "include": "#emmy-see" },
        { "include": "#emmy-version" },
        { "include": "#emmy-other-tag" },
        { "include": "#emmy-alias-member" },
        { "include": "#emmy-doc-line" }
      ]
    },

    "emmy-class": {
      "begin": "(---\\s*)(@class)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" },
        "3": { "name": "entity.name.type.class.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        {
          "match": ":",
          "name": "punctuation.separator.inheritance.lua"
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_.]*",
          "name": "entity.other.inherited-class.lua"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.lua"
        }
      ]
    },

    "emmy-field": {
      "patterns": [
        {
          "begin": "(---\\s*)(@field)(?:\\s+(public|protected|private|package))?\\s+(\\[)",
          "end": "$",
          "beginCaptures": {
            "1": { "name": "comment.line.documentation.lua" },
            "2": { "name": "storage.type.annotation.lua" },
            "3": { "name": "storage.modifier.lua" },
            "4": { "name": "punctuation.definition.bracket.begin.lua" }
          },
          "name": "comment.line.documentation.lua",
          "patterns": [
            { "include": "#emmy-type-expr" }
          ]
        },
        {
          "begin": "(---\\s*)(@field)(?:\\s+(public|protected|private|package))?\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "end": "$",
          "beginCaptures": {
            "1": { "name": "comment.line.documentation.lua" },
            "2": { "name": "storage.type.annotation.lua" },
            "3": { "name": "storage.modifier.lua" },
            "4": { "name": "entity.name.tag.lua" }
          },
          "name": "comment.line.documentation.lua",
          "patterns": [
            { "include": "#emmy-type-expr" }
          ]
        }
      ]
    },

    "emmy-param": {
      "begin": "(---\\s*|--\\s+)(@param)\\s+([a-zA-Z_][a-zA-Z0-9_]*|\\.\\.\\.)\\s*(\\?)?",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" },
        "3": { "name": "variable.parameter.lua" },
        "4": { "name": "keyword.operator.type.optional.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-return": {
      "begin": "(---\\s*|--\\s+)(@return)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-type-annotation": {
      "begin": "(---\\s*)(@type)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-alias": {
      "begin": "(---\\s*)(@alias)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" },
        "3": { "name": "entity.name.type.alias.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-generic": {
      "begin": "(---\\s*|--\\s+)(@generic)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-overload": {
      "begin": "(---\\s*|--\\s+)(@overload)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-cast": {
      "begin": "(---\\s*)(@cast)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" },
        "3": { "name": "variable.other.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-vararg": {
      "begin": "(---\\s*|--\\s+)(@vararg)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-enum": {
      "match": "(---\\s*)(@enum)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)(.*)",
      "captures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" },
        "3": { "name": "entity.name.type.enum.lua" },
        "4": { "name": "comment.line.documentation.lua" }
      }
    },

    "emmy-diagnostic": {
      "match": "(---\\s*)(@diagnostic)\\s+(disable|enable|disable-next-line|disable-line|enable-next-line|enable-line)(?:\\s*(:)\\s*([\\w-]+(?:\\s*,\\s*[\\w-]+)*))?",
      "captures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" },
        "3": { "name": "keyword.other.diagnostic.lua" },
        "4": { "name": "punctuation.separator.lua" },
        "5": { "name": "string.unquoted.diagnostic.lua" }
      }
    },

    "emmy-see": {
      "match": "(---\\s*)(@see)\\s+([a-zA-Z_][a-zA-Z0-9_.#]*)(.*)",
      "captures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" },
        "3": { "name": "entity.name.reference.lua" },
        "4": { "name": "comment.line.documentation.lua" }
      }
    },

    "emmy-version": {
      "begin": "(---\\s*)(@version)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        {
          "match": "\\b(5\\.1|5\\.2|5\\.3|5\\.4|JIT)\\b",
          "name": "support.class.lua"
        },
        {
          "match": "[<>]=?",
          "name": "keyword.operator.lua"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.lua"
        }
      ]
    },

    "emmy-other-tag": {
      "match": "(---\\s*)(@[a-zA-Z_][a-zA-Z0-9_]*)\\b(.*)",
      "captures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "storage.type.annotation.lua" },
        "3": { "name": "comment.line.documentation.lua" }
      }
    },

    "emmy-alias-member": {
      "begin": "(---\\s*)(\\|)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.lua" },
        "2": { "name": "keyword.operator.type.union.lua" }
      },
      "name": "comment.line.documentation.lua",
      "patterns": [
        {
          "match": "#.*",
          "name": "comment.line.documentation.lua"
        },
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-doc-line": {
      "match": "---.*$",
      "name": "comment.line.documentation.lua"
    },

    "emmy-type-expr": {
      "patterns": [
        { "include": "#emmy-description-separator" },
        { "include": "#emmy-type-fun" },
        { "include": "#emmy-type-table-literal" },
        { "include": "#emmy-type-paren" },
        { "include": "#emmy-type-string-literal" },
        { "include": "#emmy-type-number-literal" },
        { "include": "#emmy-type-literal-constants" },
        { "include": "#emmy-type-builtin" },
        { "include": "#emmy-type-operators" },
        { "include": "#emmy-type-name" },
        { "include": "#emmy-type-punctuation" }
      ]
    },

    "emmy-description-separator": {
      "match": "\\s+@.*$",
      "name": "comment.line.documentation.lua"
    },

    "emmy-type-fun": {
      "begin": "\\b(fun)\\s*(\\()",
      "end": "(\\))",
      "beginCaptures": {
        "1": { "name": "keyword.other.type.function.lua" },
        "2": { "name": "punctuation.definition.parameters.begin.lua" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.parameters.end.lua" }
      },
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "variable.parameter.lua" },
            "2": { "name": "punctuation.separator.type.lua" }
          }
        },
        {
          "match": "\\.\\.\\.",
          "name": "keyword.operator.vararg.lua"
        },
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-type-table-literal": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.table.begin.lua" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.table.end.lua" }
      },
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "entity.name.tag.lua" },
            "2": { "name": "punctuation.separator.type.lua" }
          }
        },
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-type-paren": {
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.group.begin.lua" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.group.end.lua" }
      },
      "patterns": [
        { "include": "#emmy-type-expr" }
      ]
    },

    "emmy-type-string-literal": {
      "patterns": [
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.lua"
        },
        {
          "match": "'[^']*'",
          "name": "string.quoted.single.lua"
        }
      ]
    },

    "emmy-type-number-literal": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.lua"
    },

    "emmy-type-literal-constants": {
      "match": "\\b(nil|true|false)\\b",
      "name": "constant.language.lua"
    },

    "emmy-type-builtin": {
      "match": "\\b(any|boolean|string|number|integer|function|table|thread|userdata|lightuserdata|void|self)\\b",
      "name": "support.type.lua"
    },

    "emmy-type-operators": {
      "patterns": [
        {
          "match": "\\[\\]",
          "name": "keyword.operator.type.array.lua"
        },
        {
          "match": "\\|",
          "name": "keyword.operator.type.union.lua"
        },
        {
          "match": "\\?",
          "name": "keyword.operator.type.optional.lua"
        },
        {
          "match": "\\.\\.\\.",
          "name": "keyword.operator.vararg.lua"
        }
      ]
    },

    "emmy-type-name": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_.]*\\b",
      "name": "entity.name.type.lua"
    },

    "emmy-type-punctuation": {
      "patterns": [
        {
          "match": "<",
          "name": "punctuation.definition.typeparameters.begin.lua"
        },
        {
          "match": ">",
          "name": "punctuation.definition.typeparameters.end.lua"
        },
        {
          "match": ":",
          "name": "punctuation.separator.type.lua"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.lua"
        },
        {
          "match": "\\[",
          "name": "punctuation.definition.bracket.begin.lua"
        },
        {
          "match": "\\]",
          "name": "punctuation.definition.bracket.end.lua"
        }
      ]
    },

    "block-comment": {
      "begin": "--\\[(=*)\\[",
      "end": "\\]\\1\\]",
      "name": "comment.block.lua",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.lua" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.lua" }
      }
    },
    "line-comment": {
      "match": "--(?!\\[=*\\[).*$",
      "name": "comment.line.double-dash.lua"
    },
    "string-double": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.lua",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.lua" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.lua" } },
      "patterns": [
        { "include": "#escape-sequence" }
      ]
    },
    "string-single": {
      "begin": "'",
      "end": "'",
      "name": "string.quoted.single.lua",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.lua" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.lua" } },
      "patterns": [
        { "include": "#escape-sequence" }
      ]
    },
    "string-long": {
      "begin": "\\[(=*)\\[",
      "end": "\\]\\1\\]",
      "name": "string.quoted.other.multiline.lua",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.lua" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.lua" } }
    },
    "escape-sequence": {
      "match": "\\\\(?:[abfnrtvz\\\\'\"]|x[0-9a-fA-F]{2}|\\d{1,3}|u\\{[0-9a-fA-F]+\\}|\\r?\\n)",
      "name": "constant.character.escape.lua"
    },
    "number": {
      "patterns": [
        {
          "match": "\\b0[xX][0-9a-fA-F]+(\\.[0-9a-fA-F]*)?([pP][+-]?[0-9]+)?\\b",
          "name": "constant.numeric.hex.lua"
        },
        {
          "match": "\\b[0-9]+(\\.[0-9]*)?([eE][+-]?[0-9]+)?\\b",
          "name": "constant.numeric.decimal.lua"
        },
        {
          "match": "\\.[0-9]+([eE][+-]?[0-9]+)?\\b",
          "name": "constant.numeric.decimal.lua"
        }
      ]
    },
    "keyword": {
      "match": "\\b(and|break|do|else|elseif|end|for|function|goto|if|in|local|not|or|repeat|return|then|until|while)\\b",
      "name": "keyword.control.lua"
    },
    "constant": {
      "match": "\\b(nil|true|false)\\b",
      "name": "constant.language.lua"
    },
    "function-definition": {
      "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_.:]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.control.lua" },
        "2": { "name": "entity.name.function.lua" }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_.]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.lua" }
      }
    },
    "method-call": {
      "match": "(:)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "keyword.operator.lua" },
        "2": { "name": "entity.name.function.method.lua" }
      }
    },
    "label": {
      "match": "(::)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(::)",
      "captures": {
        "1": { "name": "punctuation.definition.label.begin.lua" },
        "2": { "name": "entity.name.label.lua" },
        "3": { "name": "punctuation.definition.label.end.lua" }
      }
    },
    "local-function": {
      "match": "\\b(local)\\s+(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.control.lua" },
        "2": { "name": "keyword.control.lua" },
        "3": { "name": "entity.name.function.lua" }
      }
    },
    "operator": {
      "match": "\\+|-|\\*|/|//|%|\\^|#|==|~=|<=|>=|<|>|=|\\.\\.|\\.\\.\\.|\\.|\"|&|\\||~|<<|>>",
      "name": "keyword.operator.lua"
    },
    "variable": {
      "match": "\\b(self)\\b",
      "name": "variable.language.self.lua"
    }
  }
}
