{
    "information_for_contributors": [
        "for mylua. mod base on lua, add dollar_string",
        "problem-1: textmate seems can not handle \\z in string.",
        "problem-2: 当前的实现配置实现有些差呀。当时如果好好写，似乎要花好长时间，所以就这样了。"
    ],
    "version": "0.1.0",
    "name": "MyLua",
    "scopeName": "source.mylua",
    "patterns": [
        {
            "begin": "\\b(?:(local)\\s+)?(function)\\b(?![,:])",
            "beginCaptures": {
                "1": { "name": "keyword.local.mylua" },
                "2": { "name": "keyword.control.mylua" }
            },
            "end": "(?<=[\\)\\-{}\\[\\]\"'])",
            "name": "meta.function.mylua",
            "patterns": [
                { "include": "#comment" },
                {
                    "begin": "(\\()",
                    "beginCaptures": { "1": { "name": "punctuation.definition.parameters.begin.mylua" } },
                    "end": "(\\))|(?=[\\-\\.{}\\[\\]\"'])",
                    "endCaptures": { "1": { "name": "punctuation.definition.parameters.finish.mylua" } },
                    "name": "meta.parameter.mylua",
                    "patterns": [
                        { "include": "#comment" },
                        {
                            "match": "[a-zA-Z_][a-zA-Z0-9_]*",
                            "name": "variable.parameter.function.mylua"
                        },
                        {
                            "match": ",",
                            "name": "punctuation.separator.arguments.mylua"
                        },
                        {
                            "begin": ":",
                            "beginCaptures": { "0": { "name": "punctuation.separator.arguments.mylua" } },
                            "end": "(?=[\\),])",
                            "patterns": [ { "include": "#emmydoc.type" } ]
                        }
                    ]
                },
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b\\s*(?=:)",
                    "name": "entity.name.class.mylua"
                },
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "name": "entity.name.function.mylua"
                }
            ]
        },
        {
            "match": "(?<![\\w\\d.])0[xX][0-9A-Fa-f]+(\\.[0-9A-Fa-f]*)?([eE]-?\\d*)?([pP][-+]\\d+)?",
            "name": "constant.numeric.float.hexadecimal.mylua"
        },
        {
            "match": "(?<![\\w\\d.])0[xX]\\.[0-9A-Fa-f]+([eE]-?\\d*)?([pP][-+]\\d+)?",
            "name": "constant.numeric.float.hexadecimal.mylua"
        },
        {
            "match": "(?<![\\w\\d.])0[xX][0-9A-Fa-f]+(?![pPeE.0-9])",
            "name": "constant.numeric.integer.hexadecimal.mylua"
        },
        {
            "match": "(?<![\\w\\d.])\\d+(\\.\\d*)?([eE]-?\\d*)?",
            "name": "constant.numeric.float.mylua"
        },
        {
            "match": "(?<![\\w\\d.])\\.\\d+([eE]-?\\d*)?",
            "name": "constant.numeric.float.mylua"
        },
        {
            "match": "(?<![\\w\\d.])\\d+(?![pPeE.0-9])",
            "name": "constant.numeric.integer.mylua"
        },
        { "include": "#string" },
        { "include": "#dollar_string" },
        {
            "captures": { "1": { "name": "punctuation.definition.comment.mylua" } },
            "match": "\\A(#!).*$\\n?",
            "name": "comment.line.shebang.mylua"
        },
        { "include": "#comment" },
        {
            "captures": {
                "1": { "name": "keyword.control.goto.mylua" },
                "2": { "name": "string.tag.mylua" }
            },
            "match": "\\b(goto)\\s+([a-zA-Z_][a-zA-Z0-9_]*)"
        },
        {
            "captures": {
                "1": { "name": "punctuation.section.embedded.begin.mylua" },
                "2": { "name": "punctuation.section.embedded.end.mylua" }
            },
            "match": "(::)\\s*[a-zA-Z_][a-zA-Z0-9_]*\\s*(::)",
            "name": "string.tag.mylua"
        },
        {
            "match": "<\\s*(const|close)\\s*>",
            "captures": { "0": { "name": "storage.type.attribute.mylua" } }
        },
        {
            "match": "\\<[a-zA-Z_\\*][a-zA-Z0-9_\\.\\*\\-]*\\>",
            "name": "storage.type.generic.mylua"
        },
        {
            "match": "\\b(break|do|else|for|if|elseif|goto|return|then|repeat|while|until|end|in)\\b",
            "name": "keyword.control.mylua"
        },
        {
            "match": "\\b(local)\\b",
            "name": "keyword.local.mylua"
        },
        {
            "match": "\\b(function)\\b(?![,:])",
            "name": "keyword.control.mylua"
        },
        {
            "match": "(?<![^.]\\.|:)\\b(false|nil(?!:)|true|_ENV|_G|_VERSION|math\\.(pi|huge|maxinteger|mininteger)|utf8\\.charpattern|io\\.(stdin|stdout|stderr)|package\\.(config|cpath|loaded|loaders|path|preload|searchers))\\b|(?<![.])\\.{3}(?!\\.)",
            "name": "constant.language.mylua"
        },
        {
            "match": "(?<![^.]\\.|:)\\b(self)\\b",
            "name": "variable.language.self.mylua"
        },
        {
            "match": "(?<![^.]\\.|:)\\b(assert|collectgarbage|dofile|error|getfenv|getmetatable|ipairs|load|loadfile|loadstring|module|next|pairs|pcall|print|rawequal|rawget|rawlen|rawset|require|select|setfenv|setmetatable|tonumber|tostring|type|unpack|xpcall)\\b(?!\\s*=(?!=))",
            "name": "support.function.mylua"
        },
        {
            "match": "(?<![^.]\\.|:)\\b(async)\\b(?!\\s*=(?!=))",
            "name": "entity.name.tag.mylua"
        },
        {
            "match": "(?<![^.]\\.|:)\\b(coroutine\\.(create|isyieldable|close|resume|running|status|wrap|yield)|string\\.(byte|char|dump|find|format|gmatch|gsub|len|lower|match|pack|packsize|rep|reverse|sub|unpack|upper)|table\\.(concat|insert|maxn|move|pack|remove|sort|unpack)|math\\.(abs|acos|asin|atan2?|ceil|cosh?|deg|exp|floor|fmod|frexp|ldexp|log|log10|max|min|modf|pow|rad|random|randomseed|sinh?|sqrt|tanh?|tointeger|type)|io\\.(close|flush|input|lines|open|output|popen|read|tmpfile|type|write)|os\\.(clock|date|difftime|execute|exit|getenv|remove|rename|setlocale|time|tmpname)|package\\.(loadlib|seeall|searchpath)|debug\\.(debug|[gs]etfenv|[gs]ethook|getinfo|[gs]etlocal|[gs]etmetatable|getregistry|[gs]etupvalue|[gs]etuservalue|set[Cc]stacklimit|traceback|upvalueid|upvaluejoin)|bit32\\.(arshift|band|bnot|bor|btest|bxor|extract|replace|lrotate|lshift|rrotate|rshift)|utf8\\.(char|codes|codepoint|len|offset))\\b(?!\\s*=(?!=))",
            "name": "support.function.library.mylua"
        },
        {
            "match": "\\b(and|or|not|\\|\\||\\&\\&|\\!)\\b",
            "name": "keyword.operator.mylua"
        },
        {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*(?:[({\"']|\\[\\[))",
            "name": "support.function.any-method.mylua"
        },
        {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*\\??:)",
            "name": "entity.name.class.mylua"
        },
        {
            "match": "(?<=[^.]\\.|:)\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?!\\s*=\\s*\\b(function)\\b)",
            "name": "entity.other.attribute.mylua"
        },
        {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?!\\s*=\\s*\\b(function)\\b)",
            "name": "variable.other.mylua"
        },
        {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*=\\s*\\b(function)\\b)",
            "name": "entity.name.function.mylua"
        },
        {
            "match": "\\+|-|%|#|\\*|\\/|\\^|==?|~=|!=|<=?|>=?|(?<!\\.)\\.{2}(?!\\.)",
            "name": "keyword.operator.mylua"
        }
    ],
    "repository": {
        "escaped_char": {
            "patterns": [
                {
                    "match": "\\\\[abfnrtv\\\\\"'\\n]",
                    "name": "constant.character.escape.mylua"
                },
                {
                    "begin": "\\\\z",
                    "beginCaptures": { "0": { "name": "constant.character.escape.z.begin.mylua" } },
                    "end": "(?=[\\S])",
                    "endCaptures": { "0": { "name": "constant.character.escape.z.end.mylua" } },
                    "name": "constant.character.escape.z.mylua",
                    "patterns": [
                        {
                            "match": "[\\n\\t ]+",
                            "name": "constant.character.escape.z.whitespace.mylua"
                        }
                    ]
                },
                {
                    "match": "\\\\\\d{1,3}",
                    "name": "constant.character.escape.byte.mylua"
                },
                {
                    "match": "\\\\x[0-9A-Fa-f][0-9A-Fa-f]",
                    "name": "constant.character.escape.byte.mylua"
                },
                {
                    "match": "\\\\u\\{[0-9A-Fa-f]+\\}",
                    "name": "constant.character.escape.unicode.mylua"
                },
                {
                    "match": "\\\\.",
                    "name": "invalid.illegal.character.escape.mylua"
                }
            ]
        },
        "string": {
            "patterns": [
                {
                    "begin": "['\"]",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.mylua" } },
                    "end": "\\0|(?=\\n)",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.mylua" } },
                    "name": "string.quoted.mylua",
                    "patterns": [ { "include": "#escaped_char" } ]
                },
                {
                    "begin": "`",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.mylua" } },
                    "end": "`[ \\t]*|(?=\\n)",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.mylua" } },
                    "name": "string.quoted.double.mylua"
                },
                {
                    "begin": "(?<=\\.cdef)\\s*(\\[(=*)\\[)",
                    "beginCaptures": {
                        "0": { "name": "string.quoted.other.multiline.mylua" },
                        "1": { "name": "punctuation.definition.string.begin.mylua" }
                    },
                    "contentName": "meta.embedded.mylua",
                    "end": "(\\]\\2\\])[ \\t]*",
                    "endCaptures": {
                        "0": { "name": "string.quoted.other.multiline.mylua" },
                        "1": { "name": "punctuation.definition.string.end.mylua" }
                    },
                    "patterns": [ { "include": "source.c" } ]
                },
                {
                    "begin": "(?<!--)\\[(=*)\\[",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.mylua" } },
                    "end": "\\]\\1\\][ \\t]*",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.mylua" } },
                    "name": "string.quoted.other.multiline.mylua"
                }
            ]
        },
        "dollar_string": {
            "patterns": [
                {
                    "begin": "\\$(['\"])",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.mylua" } },
                    "end": "\\1|(?=\\n)",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.mylua" } },
                    "name": "string.quoted.dollar_string.mylua",
                    "patterns": [
                        {
                            "match": "\\$(?![\\$_a-zA-Z\\{])",
                            "name": "invalid.illegal.string.mylua"
                        },
                        {
                            "match": "(\\$)(\\$)",
                            "captures": {
                                "1": { "name": "constant.character.escape.mylua" },
                                "2": { "name": "string.quoted.string.dollar.mylua" }
                            },
                            "name": "meta.embedded.string.mylua"
                        },
                        {
                            "match": "(\\$)([_a-zA-Z][_a-zA-Z0-9]*)",
                            "captures": {
                                "1": { "name": "constant.character.escape.mylua" },
                                "2": { "name": "variable.other.mylua" }
                            },
                            "name": "meta.embedded.variable.string.mylua"
                        },
                        {
                            "begin": "(\\$)(\\{)",
                            "beginCaptures": {
                                "2": { "name": "constant.character.begin.string.exp.mylua" },
                                "1": { "name": "constant.character.escape.mylua" }
                            },
                            "end": "\\}|(?=\\n)",
                            "endCaptures": { "0": { "name": "constant.character.end.string.exp.mylua" } },
                            "name": "meta.embedded.exp.string.mylua",
                            "patterns": [ { "include": "source.mylua" } ]
                        },
                        { "include": "#escaped_char" }
                    ]
                }
            ]
        },
        "comment": {
            "patterns": [
                {
                    "begin": "(^[ \\t]+)?(?=--)",
                    "beginCaptures": { "1": { "name": "punctuation.whitespace.comment.leading.mylua" } },
                    "end": "(?!\\G)((?!^)[ \\t]+\\n)?",
                    "endCaptures": { "1": { "name": "punctuation.whitespace.comment.trailing.mylua" } },
                    "patterns": [
                        {
                            "begin": "--\\[(=*)\\[@@@",
                            "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.mylua" } },
                            "end": "(--)?\\]\\1\\]",
                            "endCaptures": { "0": { "name": "punctuation.definition.comment.end.mylua" } },
                            "name": "",
                            "patterns": [ { "include": "source.mylua" } ]
                        },
                        {
                            "begin": "--\\[(=*)\\[",
                            "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.mylua" } },
                            "end": "(--)?\\]\\1\\]",
                            "endCaptures": { "0": { "name": "punctuation.definition.comment.end.mylua" } },
                            "name": "comment.block.mylua",
                            "patterns": [
                                { "include": "#emmydoc" },
                                { "include": "#ldoc_tag" }
                            ]
                        },
                        {
                            "begin": "----",
                            "beginCaptures": { "0": { "name": "punctuation.definition.comment.mylua" } },
                            "end": "\\n",
                            "name": "comment.line.double-dash.mylua"
                        },
                        {
                            "begin": "---",
                            "beginCaptures": { "0": { "name": "punctuation.definition.comment.mylua" } },
                            "end": "\\n",
                            "name": "comment.line.double-dash.documentation.mylua",
                            "patterns": [
                                { "include": "#emmydoc" },
                                { "include": "#ldoc_tag" }
                            ]
                        },
                        {
                            "begin": "--",
                            "beginCaptures": { "0": { "name": "punctuation.definition.comment.mylua" } },
                            "end": "\\n",
                            "name": "comment.line.double-dash.mylua",
                            "patterns": [ { "include": "#ldoc_tag" } ]
                        }
                    ]
                },
                {
                    "begin": "\\/\\*",
                    "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.mylua" } },
                    "end": "\\*\\/",
                    "endCaptures": { "0": { "name": "punctuation.definition.comment.end.mylua" } },
                    "name": "comment.block.mylua",
                    "patterns": [
                        { "include": "#emmydoc" },
                        { "include": "#ldoc_tag" }
                    ]
                }
            ]
        },
        "emmydoc": {
            "patterns": [
                {
                    "begin": "(?<=---)[ \\t]*@class",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [
                        {
                            "match": "\\b([a-zA-Z_\\*][a-zA-Z0-9_\\.\\*\\-]*)",
                            "name": "support.class.mylua"
                        },
                        {
                            "match": ":|,",
                            "name": "keyword.operator.mylua"
                        }
                    ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@enum",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [
                        {
                            "begin": "\\b([a-zA-Z_\\*][a-zA-Z0-9_\\.\\*\\-]*)",
                            "beginCaptures": { "0": { "name": "variable.mylua" } },
                            "end": "(?=\\n)"
                        }
                    ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@type",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [ { "include": "#emmydoc.type" } ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@alias",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [
                        {
                            "begin": "\\b([a-zA-Z_\\*][a-zA-Z0-9_\\.\\*\\-]*)",
                            "beginCaptures": { "0": { "name": "variable.mylua" } },
                            "end": "(?=[\\n#])",
                            "patterns": [ { "include": "#emmydoc.type" } ]
                        }
                    ]
                },
                {
                    "begin": "(?<=---)[ \\t]*(@operator)\\s*(\\b[a-z]+)?",
                    "beginCaptures": {
                        "1": { "name": "storage.type.annotation.mylua" },
                        "2": { "name": "support.function.library.mylua" }
                    },
                    "end": "(?=[\\n@#])",
                    "patterns": [ { "include": "#emmydoc.type" } ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@cast",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [
                        {
                            "begin": "\\b([a-zA-Z_\\*][a-zA-Z0-9_\\.\\*\\-]*)",
                            "beginCaptures": { "0": { "name": "variable.other.mylua" } },
                            "end": "(?=\\n)",
                            "patterns": [
                                { "include": "#emmydoc.type" },
                                {
                                    "match": "([+-|])",
                                    "name": "keyword.operator.mylua"
                                }
                            ]
                        }
                    ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@param",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [
                        {
                            "begin": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(\\??)",
                            "beginCaptures": {
                                "1": { "name": "entity.name.variable.mylua" },
                                "2": { "name": "keyword.operator.mylua" }
                            },
                            "end": "(?=[\\n#])",
                            "patterns": [ { "include": "#emmydoc.type" } ]
                        }
                    ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@return",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [
                        {
                            "match": "\\?",
                            "name": "keyword.operator.mylua"
                        },
                        { "include": "#emmydoc.type" }
                    ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@field",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [
                        {
                            "begin": "(\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b|(\\[))(\\??)",
                            "beginCaptures": {
                                "2": { "name": "entity.name.variable.mylua" },
                                "3": { "name": "keyword.operator.mylua" }
                            },
                            "end": "(?=[\\n#])",
                            "patterns": [
                                { "include": "#string" },
                                { "include": "#emmydoc.type" },
                                {
                                    "match": "\\]",
                                    "name": "keyword.operator.mylua"
                                }
                            ]
                        }
                    ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@generic",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [
                        {
                            "begin": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                            "beginCaptures": { "0": { "name": "storage.type.generic.mylua" } },
                            "end": "(?=\\n)|(,)",
                            "endCaptures": { "0": { "name": "keyword.operator.mylua" } },
                            "patterns": [
                                {
                                    "match": ":",
                                    "name": "keyword.operator.mylua"
                                },
                                { "include": "#emmydoc.type" }
                            ]
                        }
                    ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@vararg",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [ { "include": "#emmydoc.type" } ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@overload",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [ { "include": "#emmydoc.type" } ]
                },
                {
                    "begin": "(?<=---)[ \\t]*@deprecated",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])"
                },
                {
                    "begin": "(?<=---)[ \\t]*@meta",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])"
                },
                {
                    "begin": "(?<=---)[ \\t]*@private",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])"
                },
                {
                    "begin": "(?<=---)[ \\t]*@protected",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])"
                },
                {
                    "begin": "(?<=---)[ \\t]*@package",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])"
                },
                {
                    "begin": "(?<=---)[ \\t]*@version",
                    "beginCaptures": { "0": { "name": "storage.type.annotation.mylua" } },
                    "end": "(?=[\\n@#])",
                    "patterns": [
                        {
                            "match": "\\b(5\\.1|5\\.2|5\\.3|5\\.4|JIT)\\b",
                            "name": "support.class.mylua"
                        },
                        {
                            "match": ",|\\>|\\<",
                            "name": "keyword.operator.mylua"
                        }
                    ]
                },
                {
