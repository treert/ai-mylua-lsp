{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MyLua",
  "scopeName": "source.mylua",
  "patterns": [
    {
      "include": "#shebang"
    },
    {
      "include": "#emmy-comment"
    },
    {
      "include": "#block-comment"
    },
    {
      "include": "#c-block-comment"
    },
    {
      "include": "#line-comment"
    },
    {
      "include": "#string-double"
    },
    {
      "include": "#string-single"
    },
    {
      "include": "#string-backtick"
    },
    {
      "include": "#string-long"
    },
    {
      "include": "#dollar-string"
    },
    {
      "include": "#dollar-function"
    },
    {
      "include": "#number"
    },
    {
      "include": "#keyword"
    },
    {
      "include": "#constant"
    },
    {
      "include": "#attribute"
    },
    {
      "include": "#async"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#method-call"
    },
    {
      "include": "#label"
    },
    {
      "include": "#local-function"
    },
    {
      "include": "#operator"
    },
    {
      "include": "#variable"
    }
  ],
  "repository": {
    "shebang": {
      "match": "\\A#!.*$",
      "name": "comment.line.shebang.mylua"
    },
    "emmy-comment": {
      "patterns": [
        {
          "include": "#emmy-class"
        },
        {
          "include": "#emmy-field"
        },
        {
          "include": "#emmy-param"
        },
        {
          "include": "#emmy-return"
        },
        {
          "include": "#emmy-type-annotation"
        },
        {
          "include": "#emmy-alias"
        },
        {
          "include": "#emmy-generic"
        },
        {
          "include": "#emmy-overload"
        },
        {
          "include": "#emmy-cast"
        },
        {
          "include": "#emmy-vararg"
        },
        {
          "include": "#emmy-enum"
        },
        {
          "include": "#emmy-diagnostic"
        },
        {
          "include": "#emmy-see"
        },
        {
          "include": "#emmy-version"
        },
        {
          "include": "#emmy-other-tag"
        },
        {
          "include": "#emmy-alias-member"
        },
        {
          "include": "#emmy-doc-line"
        }
      ]
    },
    "emmy-class": {
      "begin": "(---\\s*)(@class)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        },
        "3": {
          "name": "entity.name.type.class.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "match": ":",
          "name": "punctuation.separator.inheritance.mylua"
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_.]*",
          "name": "entity.other.inherited-class.mylua"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.mylua"
        }
      ]
    },
    "emmy-field": {
      "patterns": [
        {
          "begin": "(---\\s*)(@field)(?:\\s+(public|protected|private|package))?\\s+(\\[)",
          "end": "$",
          "beginCaptures": {
            "1": {
              "name": "comment.line.documentation.mylua"
            },
            "2": {
              "name": "storage.type.annotation.mylua"
            },
            "3": {
              "name": "storage.modifier.mylua"
            },
            "4": {
              "name": "punctuation.definition.bracket.begin.mylua"
            }
          },
          "name": "comment.line.documentation.mylua",
          "patterns": [
            {
              "include": "#emmy-type-expr"
            }
          ]
        },
        {
          "begin": "(---\\s*)(@field)(?:\\s+(public|protected|private|package))?\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "end": "$",
          "beginCaptures": {
            "1": {
              "name": "comment.line.documentation.mylua"
            },
            "2": {
              "name": "storage.type.annotation.mylua"
            },
            "3": {
              "name": "storage.modifier.mylua"
            },
            "4": {
              "name": "entity.name.tag.mylua"
            }
          },
          "name": "comment.line.documentation.mylua",
          "patterns": [
            {
              "include": "#emmy-type-expr"
            }
          ]
        }
      ]
    },
    "emmy-param": {
      "begin": "(---\\s*|--\\s+)(@param)\\s+([a-zA-Z_][a-zA-Z0-9_]*|\\.\\.\\.)\\s*(\\?)?",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        },
        "3": {
          "name": "variable.parameter.mylua"
        },
        "4": {
          "name": "keyword.operator.type.optional.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "include": "#emmy-param-description-without-type"
        },
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-return": {
      "begin": "(---\\s*|--\\s+)(@return)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-type-annotation": {
      "begin": "(---\\s*)(@type)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-alias": {
      "begin": "(---\\s*)(@alias)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        },
        "3": {
          "name": "entity.name.type.alias.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-generic": {
      "begin": "(---\\s*|--\\s+)(@generic)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-overload": {
      "begin": "(---\\s*|--\\s+)(@overload)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-cast": {
      "begin": "(---\\s*)(@cast)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        },
        "3": {
          "name": "variable.other.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-vararg": {
      "begin": "(---\\s*|--\\s+)(@vararg)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-enum": {
      "match": "(---\\s*)(@enum)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)(.*)",
      "captures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        },
        "3": {
          "name": "entity.name.type.enum.mylua"
        },
        "4": {
          "name": "comment.line.documentation.mylua"
        }
      }
    },
    "emmy-diagnostic": {
      "match": "(---\\s*)(@diagnostic)\\s+(disable|enable|disable-next-line|disable-line|enable-next-line|enable-line)(?:\\s*(:)\\s*([\\w-]+(?:\\s*,\\s*[\\w-]+)*))?",
      "captures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        },
        "3": {
          "name": "keyword.other.diagnostic.mylua"
        },
        "4": {
          "name": "punctuation.separator.mylua"
        },
        "5": {
          "name": "string.unquoted.diagnostic.mylua"
        }
      }
    },
    "emmy-see": {
      "match": "(---\\s*)(@see)\\s+([a-zA-Z_][a-zA-Z0-9_.#]*)(.*)",
      "captures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        },
        "3": {
          "name": "entity.name.reference.mylua"
        },
        "4": {
          "name": "comment.line.documentation.mylua"
        }
      }
    },
    "emmy-version": {
      "begin": "(---\\s*)(@version)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "match": "\\b(5\\.1|5\\.2|5\\.3|5\\.4|JIT)\\b",
          "name": "support.class.mylua"
        },
        {
          "match": "[<>]=?",
          "name": "keyword.operator.mylua"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.mylua"
        }
      ]
    },
    "emmy-other-tag": {
      "match": "(---\\s*)(@[a-zA-Z_][a-zA-Z0-9_]*)\\b(.*)",
      "captures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "storage.type.annotation.mylua"
        },
        "3": {
          "name": "comment.line.documentation.mylua"
        }
      }
    },
    "emmy-alias-member": {
      "begin": "(---\\s*)(\\|)",
      "end": "$",
      "beginCaptures": {
        "1": {
          "name": "comment.line.documentation.mylua"
        },
        "2": {
          "name": "keyword.operator.type.union.mylua"
        }
      },
      "name": "comment.line.documentation.mylua",
      "patterns": [
        {
          "match": "#.*",
          "name": "comment.line.documentation.mylua"
        },
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-doc-line": {
      "match": "---.*$",
      "name": "comment.line.documentation.mylua"
    },
    "emmy-type-expr": {
      "patterns": [
        {
          "include": "#emmy-description-separator"
        },
        {
          "include": "#emmy-return-list-description"
        },
        {
          "include": "#emmy-type-fun"
        },
        {
          "include": "#emmy-type-table-literal"
        },
        {
          "include": "#emmy-type-paren"
        },
        {
          "include": "#emmy-type-string-literal"
        },
        {
          "include": "#emmy-type-number-literal"
        },
        {
          "include": "#emmy-type-literal-constants"
        },
        {
          "include": "#emmy-type-builtin"
        },
        {
          "include": "#emmy-type-operators"
        },
        {
          "include": "#emmy-type-name"
        },
        {
          "include": "#emmy-type-punctuation"
        }
      ]
    },
    "emmy-description-separator": {
      "match": "\\s+@.*$",
      "name": "comment.line.documentation.mylua"
    },
    "emmy-return-list-description": {
      "match": "((?:[a-zA-Z_][a-zA-Z0-9_.]*\\s*,\\s*)+[a-zA-Z_][a-zA-Z0-9_.]*)(\\s+[A-Z].*)$",
      "captures": {
        "1": {
          "name": "entity.name.type.mylua"
        },
        "2": {
          "name": "comment.line.documentation.mylua"
        }
      }
    },
    "emmy-param-description-without-type": {
      "match": "\\s+[A-Z][a-zA-Z0-9_]*\\s+.*$",
      "name": "comment.line.documentation.mylua"
    },
    "emmy-type-fun": {
      "begin": "\\b(fun)\\s*(\\()",
      "end": "(\\))",
      "beginCaptures": {
        "1": {
          "name": "keyword.other.type.function.mylua"
        },
        "2": {
          "name": "punctuation.definition.parameters.begin.mylua"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.parameters.end.mylua"
        }
      },
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "variable.parameter.mylua"
            },
            "2": {
              "name": "punctuation.separator.type.mylua"
            }
          }
        },
        {
          "match": "\\.\\.\\.",
          "name": "keyword.operator.vararg.mylua"
        },
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-type-table-literal": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.table.begin.mylua"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.table.end.mylua"
        }
      },
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "entity.name.tag.mylua"
            },
            "2": {
              "name": "punctuation.separator.type.mylua"
            }
          }
        },
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-type-paren": {
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.group.begin.mylua"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.group.end.mylua"
        }
      },
      "patterns": [
        {
          "include": "#emmy-type-expr"
        }
      ]
    },
    "emmy-type-string-literal": {
      "patterns": [
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.mylua"
        },
        {
          "match": "'[^']*'",
          "name": "string.quoted.single.mylua"
        }
      ]
    },
    "emmy-type-number-literal": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.mylua"
    },
    "emmy-type-literal-constants": {
      "match": "\\b(nil|true|false)\\b",
      "name": "constant.language.mylua"
    },
    "emmy-type-builtin": {
      "match": "\\b(any|boolean|string|number|integer|function|table|thread|userdata|lightuserdata|void|self)\\b",
      "name": "support.type.mylua"
    },
    "emmy-type-operators": {
      "patterns": [
        {
          "match": "\\[\\]",
          "name": "keyword.operator.type.array.mylua"
        },
        {
          "match": "\\|",
          "name": "keyword.operator.type.union.mylua"
        },
        {
          "match": "\\?",
          "name": "keyword.operator.type.optional.mylua"
        },
        {
          "match": "\\.\\.\\.",
          "name": "keyword.operator.vararg.mylua"
        }
      ]
    },
    "emmy-type-name": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_.]*\\b",
      "name": "entity.name.type.mylua"
    },
    "emmy-type-punctuation": {
      "patterns": [
        {
          "match": "<",
          "name": "punctuation.definition.typeparameters.begin.mylua"
        },
        {
          "match": ">",
          "name": "punctuation.definition.typeparameters.end.mylua"
        },
        {
          "match": ":",
          "name": "punctuation.separator.type.mylua"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.mylua"
        },
        {
          "match": "\\[",
          "name": "punctuation.definition.bracket.begin.mylua"
        },
        {
          "match": "\\]",
          "name": "punctuation.definition.bracket.end.mylua"
        }
      ]
    },
    "block-comment": {
      "begin": "--\\[(=*)\\[",
      "end": "\\]\\1\\]",
      "name": "comment.block.mylua",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.begin.mylua"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.comment.end.mylua"
        }
      }
    },
    "line-comment": {
      "match": "--(?!\\[=*\\[).*$",
      "name": "comment.line.double-dash.mylua"
    },
    "string-double": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.mylua",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.mylua"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.mylua"
        }
      },
      "patterns": [
        {
          "include": "#escape-sequence"
        }
      ]
    },
    "string-single": {
      "begin": "'",
      "end": "'",
      "name": "string.quoted.single.mylua",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.mylua"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.mylua"
        }
      },
      "patterns": [
        {
          "include": "#escape-sequence"
        }
      ]
    },
    "string-long": {
      "begin": "\\[(=*)\\[",
      "end": "\\]\\1\\]",
      "name": "string.quoted.other.multiline.mylua",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.mylua"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.mylua"
        }
      }
    },
    "escape-sequence": {
      "match": "\\\\(?:[abfnrtvz\\\\'\"]|x[0-9a-fA-F]{2}|\\d{1,3}|u\\{[0-9a-fA-F]+\\}|\\r?\\n)",
      "name": "constant.character.escape.mylua"
    },
    "number": {
      "patterns": [
        {
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*(\\.[0-9a-fA-F_]*)?([pP][+-]?[0-9][0-9_]*)?\\b",
          "name": "constant.numeric.hex.mylua"
        },
        {
          "match": "\\b0[xX]\\.[0-9a-fA-F][0-9a-fA-F_]*([pP][+-]?[0-9][0-9_]*)?\\b",
          "name": "constant.numeric.hex.mylua"
        },
        {
          "match": "\\b[0-9][0-9_]*(\\.[0-9_]*)?([eE][+-]?[0-9][0-9_]*)?\\b",
          "name": "constant.numeric.decimal.mylua"
        },
        {
          "match": "\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?\\b",
          "name": "constant.numeric.decimal.mylua"
        }
      ]
    },
    "keyword": {
      "match": "\\b(and|break|continue|do|else|elseif|end|for|function|goto|if|in|local|not|or|repeat|return|then|until|while)\\b",
      "name": "keyword.control.mylua"
    },
    "constant": {
      "match": "\\b(nil|true|false)\\b|(?<![.])\\.\\.\\.(?!\\.)",
      "name": "constant.language.mylua"
    },
    "function-definition": {
      "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_.:]*)\\s*\\(",
      "captures": {
        "1": {
          "name": "keyword.control.mylua"
        },
        "2": {
          "name": "entity.name.function.mylua"
        }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_.]*)\\s*(?=\\()",
      "captures": {
        "1": {
          "name": "entity.name.function.call.mylua"
        }
      }
    },
    "method-call": {
      "match": "(:)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": {
          "name": "keyword.operator.mylua"
        },
        "2": {
          "name": "entity.name.function.method.mylua"
        }
      }
    },
    "label": {
