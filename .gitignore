# Dependencies & caches
node_modules/
.pnp/
.pnp.js

# Any tool cache dir under the repo — our own `.cache-mylua-lsp/`
# (summary cache, auto-created when testing the extension against
# `tests/lua-root*`), plus `.cache/`, `.pytest_cache/`, `.mypy_cache/`,
# `.ruff_cache/` and similar conventions.
.cache*/

# Build / artifacts
dist/
out/
target/
build/
*.vsix

# IDE / OS
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.sample
Thumbs.db
.DS_Store

# Claude Code — local/personal overrides and runtime-generated files
# (team-shared settings.json, agents/, commands/, skills/ DO stay in git)
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.json
.claude/todos.json
.claude/*.output

.codebuddy/plan/

# Logs & temp
*.log
.tmp/
tmp/

# Tree-sitter / native (common)
*.dylib
*.so
*.dll
